# Auth token — obtained via `node cult.js setup` (refreshed via `node cult.js login`)
AT=

# Device identity — set automatically by `setup` / `login`, do not edit manually
ENCRYPTED_DEVICE_ID=
DEVICE_ID=

# Your location — used to find nearby Cult.fit centers
# Set these to coordinates near your gym; run `node cult.js centers` to find center IDs
# Example below is the HSR Layout area, Bengaluru
LAT=12.9116
LON=77.6399
